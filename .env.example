# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Hasura GraphQL Configuration
VITE_H_PASS=your_hasura_admin_secret

# API URLs (optional)
VITE_GRAPHQL_HTTP_URL=https://owwny.hasura.app/v1/graphql
VITE_GRAPHQL_WS_URL=wss://owwny.hasura.app/v1/graphql

# Social Media Links
VITE_INSTAGRAM_URL=https://instagram.com/yourprofile
VITE_FACEBOOK_URL=https://facebook.com/yourprofile

# Analytics (optional)
VITE_GA_TRACKING_ID=
VITE_GTM_ID=
